# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=incident_analyzer

# Optional local fallback for environments without MongoDB
USE_INMEMORY_DB=false

# ─── Model Configuration ──────────────────────────────────────────────────────
# Options: "claude" (API-based, for demo) or "fine_tuned" (local Mistral checkpoint)
MODEL_TYPE=claude

# Required when MODEL_TYPE=claude
ANTHROPIC_API_KEY=sk-ant-...

# Used when MODEL_TYPE=claude — defaults to haiku (fast, cheap)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Required when MODEL_TYPE=fine_tuned
MODEL_CHECKPOINT=./checkpoints/incident-analyzer-v1/final

# ─── Integrations ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── DigitalOcean Spaces (S3-compatible storage for model artifacts) ───────────
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_BUCKET=incident-analyzer-models

# ─── Seed Data ────────────────────────────────────────────────────────────────
# Path to JSONL file to seed training incidents into DB on startup
SEED_DATA_PATH=../data/training_incidents.jsonl

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
WORKERS=2
DEBUG=false
